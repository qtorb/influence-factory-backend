{
  "name": "influence-factory-backend",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS platform for AI-powered content generation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rimraf dist && vite build",
    "build:backend": "tsc",
    "build:frontend": "vite build",
    "postinstall": "node -e \"if(process.env.DATABASE_URL){require('child_process').execSync('prisma generate',{stdio:'inherit'})}else{console.log('Skipping prisma generate (no DATABASE_URL)')}\"",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "start": "node frontend-server.js",
    "start:backend": "node dist/index.js",
    "start:frontend": "node static-server.js",
    "dev": "npm run build:backend && node dist/index.js",
    "dev:backend": "npm run build:backend && node dist/index.js",
    "dev:frontend": "vite",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "author": "Albert",
  "license": "MIT",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^5.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "redis": "^4.6.5",
    "serve": "^14.2.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.10.6",
    "@types/redis": "^4.0.10",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "prisma": "^5.8.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^8.0.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
